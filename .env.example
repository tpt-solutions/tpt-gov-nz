# === AI Configuration ===
TPT__GOV__AI_LEVEL=none            # none | advisory | assisted | automated
TPT__GOV__AI_PROVIDER=openrouter   # openrouter | ollama
TPT__GOV__AI_MODEL=anthropic/claude-sonnet-4-6
TPT__GOV__AI_BASE_URL=http://localhost:11434
TPT__GOV__AI_API_KEY=sk-or-...

# === Gateway ===
TPT__GOV__GATEWAY_LISTEN=0.0.0.0:8080
TPT__GOV__DEPT_IRD_URL=http://localhost:8090
TPT__GOV__DEPT_WINZ_URL=http://localhost:8091
TPT__GOV__DEPT_MOH_URL=http://localhost:8092
TPT__GOV__DEPT_DIA_URL=http://localhost:8093
TPT__GOV__DEPT_NZTA_URL=http://localhost:8094
TPT__GOV__DEPT_ACC_URL=http://localhost:8095
TPT__GOV__DEPT_MOJ_URL=http://localhost:8096
TPT__GOV__DEPT_POLICE_URL=http://localhost:8097
TPT__GOV__DEPT_HUD_URL=http://localhost:8098
TPT__GOV__DEPT_NZQA_URL=http://localhost:8099
TPT__GOV__DEPT_MSD_URL=http://localhost:8100
TPT__GOV__DEPT_MBIE_URL=http://localhost:8101
TPT__GOV__DEPT_LINZ_URL=http://localhost:8102
# JWT auth (HS256). If unset, auth is DISABLED for local dev.
# TPT__GOV__JWT_SECRET=change-me-in-prod
# TPT__GOV__JWT_AUDIENCE=tpt-gov-nz
# Per-department rate limit (requests per minute; default 120)
# TPT__GOV__RATE_LIMIT_RPM=120
# Circuit breaker (default: 5 failures, 30s cooldown)
# TPT__GOV__CB_FAILURE_THRESHOLD=5
# TPT__GOV__CB_COOLDOWN_SECS=30
# OpenTelemetry: set an OTLP/gRPC collector endpoint to enable trace export
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# === Identity Server ===
TPT__GOV__IDENTITY_LISTEN=0.0.0.0:8081
DATABASE_URL=postgresql://identity:identity_dev_password@localhost:5400/gov_identity

# === IRD Dept Service ===
# TPT__GOV__HTTP_LISTEN=0.0.0.0:8090
# TPT__GOV__DEPT_ID=ird
# TPT__GOV__FEDERATION_LISTEN=0.0.0.0:7001
# Federation peers (Phase 1 HTTP mock transport):
#   comma-separated dept_id@host:port#base64_public_key
# TPT__GOV__FEDERATION_PEERS=winz@127.0.0.1:7002#BASE64KEY,moh@127.0.0.1:7003#BASE64KEY

# === Portal ===
NEXT_PUBLIC_DEMO_MODE=false
# Public URL of the identity server (used by the citizen wallet to register a DID)
NEXT_PUBLIC_IDENTITY_SERVER_URL=http://localhost:8081
# Secret used to sign the portal session JWT (HS256). REQUIRED outside local dev.
TPT__GOV__SESSION_SECRET=change-me-in-prod
DEMO_CITIZEN_DID=did:gov:nz:test-citizen-001
IRD_SERVICE_URL=http://localhost:8090
WINZ_SERVICE_URL=http://localhost:8091
MOH_SERVICE_URL=http://localhost:8092
DIA_SERVICE_URL=http://localhost:8093
NZTA_SERVICE_URL=http://localhost:8094
ACC_SERVICE_URL=http://localhost:8095
MOJ_SERVICE_URL=http://localhost:8096
POLICE_SERVICE_URL=http://localhost:8097
HUD_SERVICE_URL=http://localhost:8098
NZQA_SERVICE_URL=http://localhost:8099
MSD_SERVICE_URL=http://localhost:8100
MBIE_SERVICE_URL=http://localhost:8101
LINZ_SERVICE_URL=http://localhost:8102
STATSNZ_SERVICE_URL=http://localhost:8103
CORRECTIONS_SERVICE_URL=http://localhost:8104
CUSTOMS_SERVICE_URL=http://localhost:8105
MPI_SERVICE_URL=http://localhost:8106
DOC_SERVICE_URL=http://localhost:8107
TPK_SERVICE_URL=http://localhost:8108

